<mapper namespace="com.beez.beez.logs.mapper.LogsMapper">

  <insert id="insertLogs" parameterType="com.beez.beez.logs.dto.LogsCreateRequest">
    <selectKey keyProperty="logId" resultType="string" order="BEFORE">
      SELECT BEEZ.generate_pk_auto('logs') FROM dual
    </selectKey>
    
    INSERT INTO logs (
        log_id,
        project_id,
        type,
        category,
        content,
        created_on,
        link,
        user_id
    ) VALUES (
        #{logId},
        #{projectId},
        #{type},
        #{category},
        #{content},
        SYSDATE,
        #{link},
        #{userId}
    )
  </insert>

