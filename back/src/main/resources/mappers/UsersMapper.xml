<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beez.beez.users.mapper.UsersMapper">

  <resultMap id="userMap" type="com.beez.beez.users.repository.Users">
    <id property="id" column="id"/>
    <result property="email" column="email"/>
    <result property="password" column="password"/>
    <result property="name" column="name"/>
    <result property="status" column="status"/>
    <result property="createdOn" column="created_on"/>

    <collection property="roles" ofType="string">
      <result column="role"/>
    </collection>
  </resultMap>

  <!--  로그인 -->
  <select id="findById" parameterType="string" resultMap="userMap">
    SELECT id,
           email,
           password,
           name,
           status,
           created_on,
           role
    FROM   users
    WHERE  id = #{id}
  </select>

  <!-- 사용자 목록 조회 -->
  <select id="findAllUsers"
          parameterType="com.beez.beez.users.dto.UserSearchRequest"
          resultType="com.beez.beez.users.dto.UserListResponse">
    SELECT id,
           email,
           name,
           status,
           created_on,
           role
    FROM users
    <where>
      <if test="name != null and name != ''">
        AND name LIKE '%' || #{name} || '%'
      </if>

      <if test="status != null and status != ''">
        AND status = #{status}
      </if>

      <if test="startDate != null">
        AND TRUNC(created_on) &gt;= #{startDate}
      </if>
      <if test="endDate != null">
        AND TRUNC(created_on) &lt;= #{endDate}
      </if>
    </where>
    ORDER BY created_on DESC
  </select>

  <!-- 사용자 등록 -->
  <insert id="insertUser" parameterType="com.beez.beez.users.repository.Users">
    <selectKey keyProperty="id" resultType="string" order="BEFORE">
      SELECT BEEZ.generate_pk_auto('users') FROM dual
    </selectKey>

    INSERT INTO USERS (
      id,
      email,
      password,
      name,
      status,
      created_on,
      role)
    VALUES (
      #{id},
      #{email},
      #{password},
      #{name},
      'H1',
      SYSDATE,
      #{roles[0]})
  </insert>

  <!-- 비밀번호 재설정 정보 조회 -->
  <select id="findUserForPasswordReset"
          parameterType="com.beez.beez.users.dto.PasswordResetRequest"
          resultType="com.beez.beez.users.dto.UserListResponse">
    SELECT id,
           email,
           name
    FROM   users
    WHERE  id = #{id} AND
           email = #{email} AND
           name = #{name}
  </select>

  <!-- 토큰 등록(비밀번호 재설정) -->
  <insert id="insertUserTokens" parameterType="com.beez.beez.users.dto.UserTokenDto">
    <selectKey keyProperty="tokenId" resultType="string" order="BEFORE">
      SELECT BEEZ.generate_pk_auto('user_tokens') FROM dual
    </selectKey>

    INSERT INTO user_tokens (
      TOKEN_ID,
      USER_ID,
      TOKEN_VALUE,
      TOKEN_TYPE,
      EXPIRY_DATE,
      CREATED_ON
    )
    VALUES (
      #{tokenId},
      #{userId},
      #{tokenValue},
      #{tokenType},
      SYSTIMESTAMP + INTERVAL '30' MINUTE,
      SYSTIMESTAMP
    )
  </insert>
</mapper>