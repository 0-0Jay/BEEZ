<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beez.beez.users.mapper.UsersMapper">

  <resultMap id="userMap" type="com.beez.beez.users.repository.Users">
    <id property="id" column="id"/>
    <result property="email" column="email"/>
    <result property="password" column="password"/>
    <result property="name" column="name"/>
    <result property="status" column="status"/>
    <result property="createdOn" column="created_on"/>
    
    <collection property="roles" ofType="string" javaType="java.util.ArrayList">
      <result column="role"/>
    </collection>
  </resultMap>

  <select id="findById" parameterType="string" resultMap="userMap">
    SELECT
    id, email, password, name, status, role  FROM users
    WHERE id = #{id}
  </select>

  <insert id="save" parameterType="com.beez.beez.users.dto.UsersDto">
    <selectKey keyProperty="id" resultType="string" order="BEFORE">
      SELECT BEEZ.generate_pk_auto('USERS') FROM dual
    </selectKey>

    INSERT INTO USERS (
      id,
      email,
      password,
      name,
      status,
      created_on,
      role)
    VALUES (
      #{id},
      #{email},
      #{password},
      #{name},
      'H1',
      SYSDATE,
      #{role})
  </insert>
</mapper>