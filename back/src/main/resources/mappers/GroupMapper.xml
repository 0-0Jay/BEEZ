<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beez.beez.group.mapper.GroupMapper">
  <resultMap id="groupMap" type="com.beez.beez.group.dto.GroupListResponse">
    <result property="id" column="id"/>
    <result property="name" column="name"/>
    <result property="description" column="description"/>
    <result property="memberCnt" column="member_cnt"/>
  </resultMap>
  <!-- 그룹 목록 조회 -->
  <select id="findAllGroup" resultMap="groupMap">
    SELECT g.id, g.name, g.description, COUNT(gm.user_id) AS member_cnt
    FROM groups g
    LEFT OUTER JOIN group_member gm ON g.id = gm.group_id
    <where>
      <if test="name != null and name != ''">
        AND g.name LIKE '%' || #{name} || '%'
      </if>
    </where>
    GROUP BY g.id, g.name, g.description
    ORDER BY g.name
  </select>
</mapper>