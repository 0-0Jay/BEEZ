<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beez.beez.roles.mapper.RolesMapper">

  <!-- 역할 이름 중복 체크 -->
  <select id="countByName" resultType="int">
    SELECT COUNT(*)
    FROM roles
    WHERE name = #{name}
  </select>

  <!-- 새 역할 기본 정보 등록 -->
  <insert id="insertRole" parameterType="com.beez.beez.roles.repository.Roles">
    <selectKey keyProperty="id" resultType="string" order="BEFORE">
      SELECT BEEZ.generate_pk_auto('roles') FROM dual
    </selectKey>

    INSERT INTO roles (
    id,
    name,
    is_assignee)
    VALUES (
    #{id},
    #{name},
    #{isAssignee})
  </insert>
</mapper>