<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.beez.beez.permission.mapper.PermissionMapper">

  <!-- 권한 목록 조회 -->
  <select id="findAllPermissions" resultType="com.beez.beez.permission.dto.PermissionListResponse">
    SELECT id,
           name,
           method as "method",
           url as "url"
    FROM   permission
    ORDER BY id ASC
  </select>

  <!-- 역할별 권한 매핑 정보 일괄 등록 -->
  <insert id="insertPermissionMapping">
    INSERT ALL
    <foreach collection="perIds" item="permId" separator=" ">
      INTO PERMISSION_MAPPING (role_id, perm_id)
      VALUES (#{roleId}, #{permId})
    </foreach>
    SELECT * FROM dual
  </insert>

  <!-- 역할별 권한 매핑 삭제 -->
  <delete id="deleteByRoleIdPermissionMapping">
    DELETE FROM permission_mapping WHERE role_id = #{roleId}
  </delete>
</mapper>